import {
    Button,
    CheckBox,
    LineEdit,
    ScrollView,
    VerticalBox,
    HorizontalBox,
} from "std-widgets.slint";
import { Tokens } from "paranoid-tokens.slint";

// P9.6: panic / quick-lock keyboard accelerator. `Control+L` is the GUI
// counterpart of the TUI's Ctrl+L panic key (see
// docs/guides/tui.md#panic--quick-lock-hotkey) and is documented there.
component PanicLockShortcut inherits FocusScope {
    callback panic-lock();

    // `KeyBinding` matches in the *capture* phase, which Slint dispatches
    // top-down from the window to whichever descendant currently holds
    // focus (see i-slint-core's `process_key_input`) — so this fires even
    // while a `LineEdit` (e.g. the master-password field) has focus and is
    // mid-entry, before that field's own key handling ever runs.
    KeyBinding {
        keys: @keys(Control + L);
        activated => { root.panic-lock(); }
    }
}

component FieldLabel inherits Text {
    color: Tokens.text-muted;
    font-size: Tokens.type-label-size;
    font-weight: Tokens.type-label-weight;
}

component SectionTitle inherits Text {
    color: Tokens.text-primary;
    font-size: Tokens.type-title-size;
    font-weight: Tokens.type-title-weight;
}

component BodyText inherits Text {
    color: Tokens.text-primary;
    font-size: Tokens.type-body-size;
    font-weight: Tokens.type-body-weight;
    wrap: word-wrap;
}

component EvidenceText inherits Text {
    color: Tokens.text-primary;
    font-size: Tokens.type-label-size;
    wrap: word-wrap;
}

component Panel inherits Rectangle {
    background: Tokens.bg-panel;
    border-color: Tokens.border;
    border-width: Tokens.panel-border-width;
    border-radius: Tokens.panel-radius;
}

export component ParanoidPasswdShell inherits Window {
    in property <string> mode: "Slint GUI";
    in property <string> posture: "Vault posture unavailable";
    in property <string> readiness: "Ready";
    in property <string> vault-path: "";
    in property <string> status: "Ready";
    in property <string> generated-passwords: "No passwords generated yet.";
    in property <string> audit-details: "Run an audit to produce evidence.";
    in property <string> vault-items: "Vault is locked or not loaded.";
    in property <string> keyslot-summary: "No keyslots loaded.";
    in property <string> selected-item: "No vault item selected.";
    in property <string> automation-status: "Manual mode";

    callback run-audit(string, string, bool, bool, bool);
    callback init-vault(string, string);
    callback unlock-vault(string, string);
    callback add-login(string, string, string, string, string, string, string);
    callback generate-rotate(string, string, string);
    callback enroll-mnemonic(string, string, string);
    callback export-backup(string, string, string);
    callback copy-primary();
    callback lock-vault();

    title: "paranoid-passwd";
    preferred-width: 1240px;
    preferred-height: 1020px;
    background: Tokens.bg-base;

    // Slint only dispatches key events (including the capture phase) along
    // the ancestor chain of whatever item currently holds focus; a window
    // with nothing focused yet ignores all keys. Giving `panic-lock-scope`
    // initial focus means Control+L works immediately at launch, and it
    // keeps working after the user tabs/clicks into any descendant field
    // (a `LineEdit` becoming focused does not remove `panic-lock-scope`
    // from that field's ancestor chain, so capture still reaches it first).
    forward-focus: panic-lock-scope;

    // P9.6 panic / quick-lock hotkey: `PanicLockShortcut` above wraps the
    // whole window body in a `FocusScope` + `KeyBinding` for Control+L,
    // firing `root.lock-vault()` even while a `LineEdit` (e.g. the
    // recovery-secret field) has focus and is mid-entry, since `KeyBinding`
    // matches in the capture phase before descendant key handling runs.
    panic-lock-scope := PanicLockShortcut {
        panic-lock => { root.lock-vault(); }

        VerticalLayout {
            padding: Tokens.space-base;
            spacing: Tokens.space-base;

            Rectangle {
                height: 104px;
                background: Tokens.bg-panel;
                border-color: Tokens.border;
                border-width: Tokens.panel-border-width;
                border-radius: Tokens.panel-radius;

                HorizontalLayout {
                    padding: Tokens.space-loose;
                    spacing: Tokens.space-loose;

                    VerticalLayout {
                        spacing: Tokens.space-snug;
                        width: 500px;

                        Text {
                            text: "paranoid-passwd";
                            color: Tokens.text-primary;
                            font-size: Tokens.type-title-size;
                            font-weight: Tokens.type-title-weight;
                        }

                        Text {
                            text: "Local secrets. Verifiable trust.";
                            color: Tokens.text-muted;
                            font-size: Tokens.type-body-size;
                        }
                    }

                    Rectangle {
                        width: 170px;
                        height: 54px;
                        background: Tokens.bg-panel;
                        border-color: Tokens.border;
                        border-width: Tokens.panel-border-width;
                        border-radius: Tokens.panel-radius;

                        VerticalLayout {
                            padding: Tokens.space-tight;
                            spacing: Tokens.space-tight;
                            FieldLabel { text: "SURFACE"; }
                            Text {
                                text: root.mode;
                                color: Tokens.status-caution;
                                font-size: Tokens.type-body-size;
                                font-weight: Tokens.type-title-weight;
                            }
                        }
                    }

                    Rectangle {
                        width: 355px;
                        height: 54px;
                        background: Tokens.bg-panel;
                        border-color: Tokens.border;
                        border-width: Tokens.panel-border-width;
                        border-radius: Tokens.panel-radius;

                        VerticalLayout {
                            padding: Tokens.space-tight;
                            spacing: Tokens.space-tight;
                            FieldLabel { text: "POSTURE"; }
                            Text {
                                text: root.posture;
                                color: Tokens.status-verified;
                                font-size: Tokens.type-label-size;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }

            GridLayout {
                spacing: Tokens.space-base;

                Row {
                    Panel {
                        width: 390px;
                        height: 440px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;

                            SectionTitle { text: "Generator"; }
                            BodyText {
                                text: "Run the audited Rust core. The GUI submits policy; paranoid-core owns entropy, rejection sampling, and compliance math.";
                            }

                            HorizontalBox {
                                spacing: Tokens.space-snug;
                                VerticalLayout {
                                    spacing: Tokens.space-tight;
                                    FieldLabel { text: "Length"; }
                                    gen-length := LineEdit {
                                        text: "32";
                                        placeholder-text: "32";
                                    }
                                }
                                VerticalLayout {
                                    spacing: Tokens.space-tight;
                                    FieldLabel { text: "Count"; }
                                    gen-count := LineEdit {
                                        text: "1";
                                        placeholder-text: "1";
                                    }
                                }
                            }

                            HorizontalBox {
                                nist := CheckBox { text: "NIST"; checked: true; }
                                pci := CheckBox { text: "PCI DSS"; }
                                soc2 := CheckBox { text: "SOC 2"; }
                            }

                            HorizontalBox {
                                run-audit-button := Button {
                                    text: "Run audit";
                                    clicked => {
                                        root.run-audit(gen-length.text, gen-count.text, nist.checked, pci.checked, soc2.checked);
                                    }
                                }
                                copy-primary-button := Button {
                                    text: "Copy primary";
                                    clicked => { root.copy-primary(); }
                                }
                            }
                        }
                    }

                    Panel {
                        width: 390px;
                        height: 440px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;

                            SectionTitle { text: "Vault Access"; }
                            BodyText {
                                text: "Unlock a local encrypted vault and perform item, rotation, recovery, and backup operations through typed ops policy and paranoid-vault.";
                            }

                            FieldLabel { text: "Vault path"; }
                            vault-path-input := LineEdit {
                                text: root.vault-path;
                                placeholder-text: "vault.sqlite";
                            }

                            FieldLabel { text: "Recovery secret"; }
                            vault-secret := LineEdit {
                                input-type: InputType.password;
                                placeholder-text: "enter local recovery secret";
                            }

                            HorizontalBox {
                                init-vault-button := Button {
                                    text: "Init";
                                    clicked => { root.init-vault(vault-path-input.text, vault-secret.text); }
                                }
                                unlock-vault-button := Button {
                                    text: "Unlock";
                                    clicked => { root.unlock-vault(vault-path-input.text, vault-secret.text); }
                                }
                            }

                            // P9.6: explicit panic / quick-lock action,
                            // equivalent to the Control+L accelerator above.
                            // Always enabled (a no-op on an already-locked
                            // vault) so a mouse-only user has the same fast
                            // exit as the keyboard shortcut.
                            lock-vault-button := Button {
                                text: "Lock vault (Ctrl+L)";
                                clicked => { root.lock-vault(); }
                            }
                        }
                    }

                    Panel {
                        width: 390px;
                        height: 440px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;

                            SectionTitle { text: "Operations"; }
                            FieldLabel { text: "TYPED OPS POLICY"; }

                            HorizontalBox {
                                login-title := LineEdit { placeholder-text: "Title"; text: "GitHub"; }
                                login-user := LineEdit { placeholder-text: "Username"; text: "octocat"; }
                            }

                            login-password := LineEdit {
                                input-type: InputType.password;
                                placeholder-text: "Existing password";
                            }

                            HorizontalBox {
                                login-folder := LineEdit { placeholder-text: "Folder"; text: "Work"; }
                                login-tags := LineEdit { placeholder-text: "Tags"; text: "work,code"; }
                            }

                            HorizontalBox {
                                rotate-length := LineEdit { text: "28"; placeholder-text: "Rotate length"; }
                                mnemonic-label := LineEdit { text: "paper-backup"; placeholder-text: "Mnemonic label"; }
                            }

                            backup-path := LineEdit {
                                placeholder-text: "Backup output path";
                            }

                            HorizontalBox {
                                add-login-button := Button {
                                    text: "Add login";
                                    clicked => {
                                        root.add-login(vault-path-input.text, vault-secret.text, login-title.text, login-user.text, login-password.text, login-folder.text, login-tags.text);
                                    }
                                }
                                rotate-button := Button {
                                    text: "Rotate";
                                    clicked => { root.generate-rotate(vault-path-input.text, vault-secret.text, rotate-length.text); }
                                }
                            }

                            HorizontalBox {
                                enroll-mnemonic-button := Button {
                                    text: "Enroll mnemonic";
                                    clicked => { root.enroll-mnemonic(vault-path-input.text, vault-secret.text, mnemonic-label.text); }
                                }
                                export-backup-button := Button {
                                    text: "Export backup";
                                    clicked => { root.export-backup(vault-path-input.text, vault-secret.text, backup-path.text); }
                                }
                            }
                        }
                    }
                }

                Row {
                    Panel {
                        width: 390px;
                        height: 340px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;
                            SectionTitle { text: "Audit Evidence"; }
                            ScrollView {
                                viewport-height: 255px;
                                EvidenceText {
                                    width: parent.width - 4px;
                                    text: root.audit-details + "\n\n" + root.generated-passwords;
                                }
                            }
                        }
                    }

                    Panel {
                        width: 390px;
                        height: 340px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;
                            SectionTitle { text: "Vault Records"; }
                            ScrollView {
                                viewport-height: 255px;
                                EvidenceText {
                                    width: parent.width - 4px;
                                    text: root.vault-items + "\n\n" + root.selected-item;
                                }
                            }
                        }
                    }

                    Panel {
                        width: 390px;
                        height: 340px;

                        VerticalBox {
                            padding: Tokens.space-base;
                            spacing: Tokens.space-base;
                            SectionTitle { text: "Assurance"; }
                            BodyText {
                                text: root.readiness;
                            }
                            Rectangle {
                                height: 1px;
                                background: Tokens.border;
                            }
                            FieldLabel { text: "KEYSLOTS"; }
                            ScrollView {
                                viewport-height: 120px;
                                EvidenceText {
                                    width: parent.width - 4px;
                                    text: root.keyslot-summary;
                                }
                            }
                            FieldLabel { text: "AUTOMATION"; }
                            EvidenceText { text: root.automation-status; }
                        }
                    }
                }
            }

            Rectangle {
                height: 46px;
                background: Tokens.bg-panel;
                border-color: Tokens.border;
                border-width: Tokens.panel-border-width;
                border-radius: Tokens.panel-radius;

                Text {
                    x: Tokens.space-base;
                    y: Tokens.space-tight;
                    width: parent.width - (2 * Tokens.space-base);
                    text: root.status;
                    color: Tokens.text-primary;
                    font-size: Tokens.type-body-size;
                    wrap: word-wrap;
                }
            }
        }
    }
}
