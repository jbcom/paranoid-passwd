import {
    Button,
    CheckBox,
    LineEdit,
    ScrollView,
    VerticalBox,
    HorizontalBox,
} from "std-widgets.slint";

component FieldLabel inherits Text {
    color: #b8c0d8;
    font-size: 13px;
}

component SectionTitle inherits Text {
    color: #f2f5ff;
    font-size: 21px;
    font-weight: 700;
}

component BodyText inherits Text {
    color: #cbd3e7;
    font-size: 15px;
    wrap: word-wrap;
}

component EvidenceText inherits Text {
    color: #dbe4f0;
    font-size: 13px;
    wrap: word-wrap;
}

component Panel inherits Rectangle {
    background: #171d26;
    border-color: #314154;
    border-width: 1px;
    border-radius: 6px;
}

export component ParanoidPasswdShell inherits Window {
    in property <string> mode: "Slint GUI";
    in property <string> posture: "Vault posture unavailable";
    in property <string> readiness: "Ready";
    in property <string> vault-path: "";
    in property <string> status: "Ready";
    in property <string> generated-passwords: "No passwords generated yet.";
    in property <string> audit-details: "Run an audit to produce evidence.";
    in property <string> vault-items: "Vault is locked or not loaded.";
    in property <string> keyslot-summary: "No keyslots loaded.";
    in property <string> selected-item: "No vault item selected.";
    in property <string> automation-status: "Manual mode";

    callback run-audit(string, string, bool, bool, bool);
    callback init-vault(string, string);
    callback unlock-vault(string, string);
    callback add-login(string, string, string, string, string, string, string);
    callback generate-rotate(string, string, string);
    callback enroll-mnemonic(string, string, string);
    callback export-backup(string, string, string);
    callback copy-primary();

    title: "paranoid-passwd";
    preferred-width: 1240px;
    preferred-height: 1020px;
    background: #0f141b;

    VerticalLayout {
        padding: 18px;
        spacing: 14px;

        Rectangle {
            height: 104px;
            background: #111822;
            border-color: #405368;
            border-width: 1px;
            border-radius: 6px;

            HorizontalLayout {
                padding: 20px;
                spacing: 22px;

                VerticalLayout {
                    spacing: 6px;
                    width: 500px;

                    Text {
                        text: "paranoid-passwd";
                        color: #f6f8ff;
                        font-size: 34px;
                        font-weight: 800;
                    }

                    Text {
                        text: "Local secrets. Verifiable trust.";
                        color: #9fd4c9;
                        font-size: 18px;
                    }
                }

                Rectangle {
                    width: 170px;
                    height: 54px;
                    background: #1f2a37;
                    border-color: #4c6178;
                    border-width: 1px;
                    border-radius: 4px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 2px;
                        FieldLabel { text: "SURFACE"; }
                        Text {
                            text: root.mode;
                            color: #f5d76e;
                            font-size: 16px;
                            font-weight: 700;
                        }
                    }
                }

                Rectangle {
                    width: 355px;
                    height: 54px;
                    background: #1b2a26;
                    border-color: #487263;
                    border-width: 1px;
                    border-radius: 4px;

                    VerticalLayout {
                        padding: 8px;
                        spacing: 2px;
                        FieldLabel { text: "POSTURE"; }
                        Text {
                            text: root.posture;
                            color: #a7e3c1;
                            font-size: 14px;
                            wrap: word-wrap;
                        }
                    }
                }
            }
        }

        GridLayout {
            spacing: 14px;

            Row {
                Panel {
                    width: 390px;
                    height: 440px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;

                        SectionTitle { text: "Generator"; }
                        BodyText {
                            text: "Run the audited Rust core. The GUI submits policy; paranoid-core owns entropy, rejection sampling, and compliance math.";
                        }

                        HorizontalBox {
                            spacing: 8px;
                            VerticalLayout {
                                spacing: 4px;
                                FieldLabel { text: "Length"; }
                                gen-length := LineEdit {
                                    text: "32";
                                    placeholder-text: "32";
                                }
                            }
                            VerticalLayout {
                                spacing: 4px;
                                FieldLabel { text: "Count"; }
                                gen-count := LineEdit {
                                    text: "1";
                                    placeholder-text: "1";
                                }
                            }
                        }

                        HorizontalBox {
                            nist := CheckBox { text: "NIST"; checked: true; }
                            pci := CheckBox { text: "PCI DSS"; }
                            soc2 := CheckBox { text: "SOC 2"; }
                        }

                        HorizontalBox {
                            Button {
                                text: "Run audit";
                                clicked => {
                                    root.run-audit(gen-length.text, gen-count.text, nist.checked, pci.checked, soc2.checked);
                                }
                            }
                            Button {
                                text: "Copy primary";
                                clicked => { root.copy-primary(); }
                            }
                        }
                    }
                }

                Panel {
                    width: 390px;
                    height: 440px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;

                        SectionTitle { text: "Vault Access"; }
                        BodyText {
                            text: "Unlock a local encrypted vault and perform item, rotation, recovery, and backup operations through typed ops policy and paranoid-vault.";
                        }

                        FieldLabel { text: "Vault path"; }
                        vault-path-input := LineEdit {
                            text: root.vault-path;
                            placeholder-text: "vault.sqlite";
                        }

                        FieldLabel { text: "Recovery secret"; }
                        vault-secret := LineEdit {
                            input-type: InputType.password;
                            placeholder-text: "enter local recovery secret";
                        }

                        HorizontalBox {
                            Button {
                                text: "Init";
                                clicked => { root.init-vault(vault-path-input.text, vault-secret.text); }
                            }
                            Button {
                                text: "Unlock";
                                clicked => { root.unlock-vault(vault-path-input.text, vault-secret.text); }
                            }
                        }
                    }
                }

                Panel {
                    width: 390px;
                    height: 440px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;

                        SectionTitle { text: "Operations"; }
                        FieldLabel { text: "TYPED OPS POLICY"; }

                        HorizontalBox {
                            login-title := LineEdit { placeholder-text: "Title"; text: "GitHub"; }
                            login-user := LineEdit { placeholder-text: "Username"; text: "octocat"; }
                        }

                        login-password := LineEdit {
                            input-type: InputType.password;
                            placeholder-text: "Existing password";
                        }

                        HorizontalBox {
                            login-folder := LineEdit { placeholder-text: "Folder"; text: "Work"; }
                            login-tags := LineEdit { placeholder-text: "Tags"; text: "work,code"; }
                        }

                        HorizontalBox {
                            rotate-length := LineEdit { text: "28"; placeholder-text: "Rotate length"; }
                            mnemonic-label := LineEdit { text: "paper-backup"; placeholder-text: "Mnemonic label"; }
                        }

                        backup-path := LineEdit {
                            placeholder-text: "Backup output path";
                        }

                        HorizontalBox {
                            Button {
                                text: "Add login";
                                clicked => {
                                    root.add-login(vault-path-input.text, vault-secret.text, login-title.text, login-user.text, login-password.text, login-folder.text, login-tags.text);
                                }
                            }
                            Button {
                                text: "Rotate";
                                clicked => { root.generate-rotate(vault-path-input.text, vault-secret.text, rotate-length.text); }
                            }
                        }

                        HorizontalBox {
                            Button {
                                text: "Enroll mnemonic";
                                clicked => { root.enroll-mnemonic(vault-path-input.text, vault-secret.text, mnemonic-label.text); }
                            }
                            Button {
                                text: "Export backup";
                                clicked => { root.export-backup(vault-path-input.text, vault-secret.text, backup-path.text); }
                            }
                        }
                    }
                }
            }

            Row {
                Panel {
                    width: 390px;
                    height: 340px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;
                        SectionTitle { text: "Audit Evidence"; }
                        ScrollView {
                            viewport-height: 255px;
                            EvidenceText {
                                width: parent.width - 4px;
                                text: root.audit-details + "\n\n" + root.generated-passwords;
                            }
                        }
                    }
                }

                Panel {
                    width: 390px;
                    height: 340px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;
                        SectionTitle { text: "Vault Records"; }
                        ScrollView {
                            viewport-height: 255px;
                            EvidenceText {
                                width: parent.width - 4px;
                                text: root.vault-items + "\n\n" + root.selected-item;
                            }
                        }
                    }
                }

                Panel {
                    width: 390px;
                    height: 340px;

                    VerticalBox {
                        padding: 18px;
                        spacing: 10px;
                        SectionTitle { text: "Assurance"; }
                        BodyText {
                            text: root.readiness;
                        }
                        Rectangle {
                            height: 1px;
                            background: #405368;
                        }
                        FieldLabel { text: "KEYSLOTS"; }
                        ScrollView {
                            viewport-height: 120px;
                            EvidenceText {
                                width: parent.width - 4px;
                                text: root.keyslot-summary;
                            }
                        }
                        FieldLabel { text: "AUTOMATION"; }
                        EvidenceText { text: root.automation-status; }
                    }
                }
            }
        }

        Rectangle {
            height: 46px;
            background: #121922;
            border-color: #314154;
            border-width: 1px;
            border-radius: 5px;

            Text {
                x: 16px;
                y: 12px;
                width: parent.width - 32px;
                text: root.status;
                color: #f2f5ff;
                font-size: 14px;
                wrap: word-wrap;
            }
        }
    }
}
