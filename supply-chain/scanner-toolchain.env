# shellcheck shell=sh
#
# Repository-owned scanner/toolchain update manifest.
#
# This file is sourced by scripts/supply_chain_verify.sh. Keep it to simple
# KEY=value assignments so the shell verifier can enforce it without adding
# a parser dependency.

SCANNER_TOOLCHAIN_SCHEMA_VERSION=1

# Wolfi apk packages installed into .github/actions/builder/Dockerfile.
# Versions were checked against the digest-pinned Wolfi base image package
# index for linux/amd64 and linux/arm64.
BUILDER_SCANNER_TOOLS="semgrep osv-scanner syft trivy"
SEMGREP_APK_PACKAGE=semgrep
SEMGREP_APK_VERSION=1.165.0-r0
OSV_SCANNER_APK_PACKAGE=osv-scanner
OSV_SCANNER_APK_VERSION=2.4.0-r0
SYFT_APK_PACKAGE=syft
SYFT_APK_VERSION=1.45.1-r1
TRIVY_APK_PACKAGE=trivy
TRIVY_APK_VERSION=0.70.0-r5

# Pinned GitHub-hosted scanner action references.
CODEQL_ACTION_VERSION=4.36.2
CODEQL_ACTION_SHA=8aad20d150bbac5944a9f9d289da16a4b0d87c1e

# Host-local scanner tools that make quality gates stricter when installed.
# These versions are checked by xtask when PARANOID_STRICT_EXTERNAL_TOOLS=1,
# which is the mode used by make quality. Updating one of these tools must
# update the version pin here and rerun the local quality gate.
HOST_LOCAL_SCANNER_TOOLS="shellcheck cargo-deny cargo-audit cargo-vet codeql"
HOST_SHELLCHECK_VERSION=0.11.0
HOST_CARGO_DENY_VERSION=0.19.4
HOST_CARGO_AUDIT_VERSION=0.22.1
HOST_CARGO_VET_VERSION=0.10.2
HOST_CODEQL_CLI_VERSION=2.25.3
